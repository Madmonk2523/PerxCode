{
  "expo": {
    "name": "geo-rewards-app",
    "slug": "geo-rewards-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "georewardsapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Geo Rewards uses your location to detect nearby businesses and award tokens.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Geo Rewards can keep checking nearby rewards while the app is in the background.",
        "UIBackgroundModes": [
          "location"
        ]
      },
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "POST_NOTIFICATIONS",
        "CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PERX to access your photos so you can choose a profile picture.",
          "cameraPermission": "Allow PERX to use your camera so you can take a profile picture."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "firebaseApiKey": "AIzaSyATjIFByHZBBGr1R-L7euVmjohoOQm0nJA",
      "firebaseAuthDomain": "app-idea-adam.firebaseapp.com",
      "firebaseProjectId": "app-idea-adam",
      "firebaseStorageBucket": "app-idea-adam.firebasestorage.app",
      "firebaseMessagingSenderId": "871917956722",
      "firebaseAppId": "1:871917956722:web:4772cf99fde973cca09ceb"
    }
  }
}
